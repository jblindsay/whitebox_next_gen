TARGET_DIR = ./rust-target
BUILD_PROFILE = $(if $(filter true,$(WBW_R_PACKAGE_RELEASE)),release,debug)
LIBDIR = $(TARGET_DIR)/$(BUILD_PROFILE)
STATLIB = $(LIBDIR)/libwbw_r.a
CARGO_MANIFEST = $(firstword $(wildcard ../../Cargo.toml ../../../Cargo.toml))
CARGO_FEATURES =
WRAPPER_TIER = open
CARGO_PROFILE_FLAG =

ifeq ($(CARGO_MANIFEST),)
$(error Could not find wbw_r Cargo.toml. Tried ../../Cargo.toml and ../../../Cargo.toml from $(CURDIR))
endif

ifeq ($(WBW_R_PACKAGE_PRO),true)
CARGO_FEATURES += --features pro
WRAPPER_TIER = pro
endif

ifeq ($(BUILD_PROFILE),release)
CARGO_PROFILE_FLAG = --release
endif

PKG_LIBS = $(STATLIB)

all: $(SHLIB)

.PHONY: $(STATLIB)

$(SHLIB): $(STATLIB)

$(STATLIB):
	cargo build -p wbw_r $(CARGO_FEATURES) $(CARGO_PROFILE_FLAG) --lib --manifest-path=$(CARGO_MANIFEST) --target-dir=$(TARGET_DIR)
	cargo run -p wbw_r $(CARGO_FEATURES) $(CARGO_PROFILE_FLAG) --example generate_r_wrappers --manifest-path=$(CARGO_MANIFEST) --target-dir=$(TARGET_DIR) -- --tier $(WRAPPER_TIER) --output ../R/zz_generated_wrappers.R

clean:
	rm -Rf $(SHLIB) $(STATLIB) $(OBJECTS) $(TARGET_DIR)
